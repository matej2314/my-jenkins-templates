pipeline {
    agent any

    stages {
        stage('Validate parameters') {
            steps {
                script {
                    build job: 'validate-params', parameters: [
                        string(name: 'CONT_NAME', value: params.CONT_NAME),
                        string(name: 'GITHUB_REPO_URL', value: params.GITHUB_REPO_URL)
                    ]
                }
            }
        }
        
        stage('Create project directory') {
            steps {
                script {
                    echo "Checking if directory ${CONT_NAME} exists"
                    
                    def dirExists = sh(script: "test -d ${CONT_NAME} && echo true || echo false", returnStdout: true).trim()
                    
                    if (dirExists == 'true') {
                        echo "Directory ${CONT_NAME} already exists. Using it."
                    } else {
                        echo "Creating directory ${CONT_NAME}"
                        sh "mkdir ${CONT_NAME}"
                    }
                }
            }
        }
        
        stage('Clone') {
            steps {
                dir("${CONT_NAME}") {
                    script {
                        echo "Cloning repository from ${GITHUB_REPO_URL}"
                        git url: "${GITHUB_REPO_URL}", branch: 'main'
                    }
                }
            }
        }

        stage('Security Scan with Snyk') {
            steps {
                dir("${CONT_NAME}") {
                    script {
                        echo "Running Snyk security scan..."
                        
                        sh 'snyk --version'
                        
                        if (fileExists('package.json')) {
                            echo "Scanning npm dependencies..."
                            sh 'snyk test --severity-threshold=high'
                        }
                        
                        if (fileExists('Dockerfile')) {
                            echo "Scanning Docker image..."
                            sh 'snyk container test . --severity-threshold=high'
                        }
                        
                        if (fileExists('docker-compose.yml')) {
                            echo "Scanning docker-compose services..."
                            sh 'snyk iac test docker-compose.yml --severity-threshold=high'
                        }
                        
                        echo "Snyk security scan completed"
                    }
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                dir("${CONT_NAME}") {
                    script {
                        sh 'docker --version'
                        sh "docker build -t ${CONT_NAME}:latest -f Dockerfile ."
                    }
                }
            }
        }
    }
}